#!/bin/sh
case "$1" in
    start)
        wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant/wpa_supplicant.conf
        sleep 3
        udhcpc -i wlan0 &
        ;;
    stop)
        killall wpa_supplicant
        killall udhcpc
        ;;
    *)
        echo "Uso: $0 {start|stop}"
        exit 1
esac
exit 0
