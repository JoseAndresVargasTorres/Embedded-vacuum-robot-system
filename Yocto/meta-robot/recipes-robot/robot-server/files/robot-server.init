#!/bin/sh
case "$1" in
    start)
        echo "Iniciando robot-server..."
        cd /opt/robot-server
        nohup python3 /opt/robot-server/server.py >/tmp/robot-server.log 2>&1 &
        ;;
    stop)
        echo "Deteniendo robot-server..."
        killall python3 2>/dev/null || true
        ;;
    *)
        echo "Uso: $0 {start|stop}"
        exit 1
esac
exit 0
