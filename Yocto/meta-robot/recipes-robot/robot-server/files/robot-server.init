#!/bin/sh
case "$1" in
    start)
        echo "Iniciando robot-server..."
        cd /opt/robot-server
        python3 /opt/robot-server/server.py &
        ;;
    stop)
        echo "Deteniendo robot-server..."
        killall python3
        ;;
    *)
        echo "Uso: $0 {start|stop}"
        exit 1
esac
exit 0
